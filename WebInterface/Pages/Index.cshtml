@page
@model WebInterface.Pages.IndexModel 
@{
ViewData["Title"] = "Consulta de Clientes";

var possuiResultado = Model.Resultado is not null;
var statusClass = Model.Resultado?.Sucesso == true ? "success" : "warning";
}


<main class="alfa-page">
    <section class="hero">
        <div class="hero-main">
            <div class="hero-eyebrow">Modernização Alfa · COBOL + .NET</div>
            <h1>Consulta e atualização de clientes</h1>
            <p>
                Interface web para consultar dados cadastrais e atualizar informações de contato,
                consumindo o proxy local que simula o papel do z/OS Connect.
            </p>
        </div>

        <aside class="hero-side" aria-label="Fluxo da solução">
            <div class="flow-step">
                <span class="flow-number">1</span>
                <span>Atendente informa o código do cliente.</span>
            </div>
            <div class="flow-step">
                <span class="flow-number">2</span>
                <span>A aplicação chama o proxy local em HTTP/JSON.</span>
            </div>
            <div class="flow-step">
                <span class="flow-number">3</span>
                <span>O retorno é exibido de forma simples para o usuário.</span>
            </div>
        </aside>
    </section>

    <section class="content-grid">
        <div>
            <form method="post" asp-page-handler="Consultar" class="form-card">
                <div class="card-title">
                    <h2>Consultar cliente</h2>
                    <span class="badge-soft">GET /api/clientes</span>
                </div>

                <div class="field-group">
                    <label asp-for="Codigo">Código do cliente</label>
                    <input asp-for="Codigo" placeholder="Ex: 000001" maxlength="6" autocomplete="off" />
                    <div class="field-help">Use o código de negócio do cliente, mantendo os zeros à esquerda.</div>
                </div>

                <div class="button-row">
                    <button class="btn-alfa" type="submit">Consultar</button>
                </div>
            </form>

            <form method="post" asp-page-handler="Atualizar" class="form-card">
                <div class="card-title">
                    <h2>Atualizar contato</h2>
                    <span class="badge-soft">PUT /api/clientes</span>
                </div>

                <div class="field-group">
                    <label asp-for="Codigo">Código do cliente</label>
                    <input asp-for="Codigo" placeholder="Ex: 000001" maxlength="6" autocomplete="off" />
                </div>

                <div class="field-group">
                    <label asp-for="Telefone">Telefone</label>
                    <input asp-for="Telefone" placeholder="Ex: 62999990000" maxlength="11" autocomplete="off" />
                    <div class="field-help">Informe apenas números, com DDD.</div>
                </div>

                <div class="field-group">
                    <label asp-for="Email">E-mail</label>
                    <input asp-for="Email" placeholder="cliente@email.com" autocomplete="off" />
                </div>

                <div class="button-row">
                    <button class="btn-secondary-alfa" type="submit">Salvar contato</button>
                </div>
            </form>
        </div>

        <div class="result-area">
            @if (!string.IsNullOrWhiteSpace(Model.Erro))
            {
            <div class="alert-box">
                @Model.Erro
            </div>
            }

            @if (possuiResultado)
            {
            <article class="result-card @statusClass">
                <header class="result-header">
                    <div>
                        <h2>@(Model.Resultado!.Sucesso ? "Operação concluída" : "Atenção")</h2>
                        <p class="message-text">@Model.Resultado.Mensagem</p>
                    </div>
                    <span class="return-code">@Model.Resultado.CodigoRetorno</span>
                </header>

                @if (Model.Resultado.Cliente is not null)
                {
                <div class="data-grid">
                    <div class="data-item">
                        <div class="data-label">ID interno</div>
                        <div class="data-value">@(Model.Resultado.Cliente.Id?.ToString() ?? "-")</div>
                    </div>

                    <div class="data-item">
                        <div class="data-label">Código</div>
                        <div class="data-value">@Model.Resultado.Cliente.Codigo</div>
                    </div>

                    <div class="data-item">
                        <div class="data-label">Nome</div>
                        <div class="data-value">@Model.Resultado.Cliente.Nome</div>
                    </div>

                    <div class="data-item">
                        <div class="data-label">Telefone</div>
                        <div class="data-value">@Model.Resultado.Cliente.Telefone</div>
                    </div>

                    <div class="data-item" style="grid-column: 1 / -1;">
                        <div class="data-label">E-mail</div>
                        <div class="data-value">@Model.Resultado.Cliente.Email</div>
                    </div>
                </div>
                }
            </article>
            }
            else
            {
            <div class="empty-state">
                <strong>Nenhuma operação realizada ainda</strong>
                <span>Consulte um cliente ou atualize os dados de contato para visualizar o retorno do proxy.</span>
            </div>
            }
        </div>
    </section>
</main>